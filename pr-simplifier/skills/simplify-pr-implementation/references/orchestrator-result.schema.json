{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PR simplification orchestrator result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "reviewed_base_sha",
    "reviewed_head_sha",
    "summary",
    "reviewed_files",
    "specialists",
    "improvements",
    "changed_files",
    "tests_changed",
    "verification",
    "remaining_observations",
    "blocking_reasons"
  ],
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "status": {
      "type": "string",
      "enum": ["clean", "simplified", "blocked", "simplified_blocked"]
    },
    "reviewed_base_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "reviewed_head_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "summary": {"type": "string", "minLength": 1, "maxLength": 2000},
    "reviewed_files": {"$ref": "#/$defs/paths"},
    "specialists": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "summary", "inspected_files", "accepted_improvement_ids"],
        "properties": {
          "name": {
            "type": "string",
            "enum": ["reuse-abstractions", "quality-maintainability", "efficiency-performance"]
          },
          "summary": {"type": "string", "minLength": 1, "maxLength": 2000},
          "inspected_files": {"$ref": "#/$defs/paths"},
          "accepted_improvement_ids": {
            "type": "array",
            "uniqueItems": true,
            "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,63}$"}
          }
        }
      }
    },
    "improvements": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "category", "evidence", "benefit", "why_behavior_is_preserved", "files", "focused_checks"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,63}$"},
          "category": {
            "type": "string",
            "enum": ["reuse", "quality", "efficiency", "tests"]
          },
          "evidence": {"type": "string", "minLength": 1, "maxLength": 3000},
          "benefit": {"type": "string", "minLength": 1, "maxLength": 2000},
          "why_behavior_is_preserved": {"type": "string", "minLength": 1, "maxLength": 3000},
          "files": {"$ref": "#/$defs/nonEmptyPaths"},
          "focused_checks": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1, "maxLength": 500}
          }
        }
      }
    },
    "changed_files": {"$ref": "#/$defs/paths"},
    "tests_changed": {"$ref": "#/$defs/paths"},
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["performed", "verdict", "summary", "commands"],
      "properties": {
        "performed": {"type": "boolean"},
        "verdict": {"type": "string", "enum": ["passed", "blocked", "not_needed"]},
        "summary": {"type": "string", "minLength": 1, "maxLength": 2000},
        "commands": {
          "type": "array",
          "items": {"type": "string", "minLength": 1, "maxLength": 500}
        }
      }
    },
    "remaining_observations": {
      "type": "array",
      "items": {"type": "string", "minLength": 1, "maxLength": 1000}
    },
    "blocking_reasons": {
      "type": "array",
      "items": {"type": "string", "minLength": 1, "maxLength": 1000}
    }
  },
  "$defs": {
    "path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
    },
    "paths": {
      "type": "array",
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/path"}
    },
    "nonEmptyPaths": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/path"}
    }
  }
}
