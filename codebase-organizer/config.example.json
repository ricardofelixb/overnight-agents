{
  "enabled": false,
  "schedule": "30 2,8,14,20 * * *",
  "provider": "codex",
  "codex_model": "gpt-5.6-terra",
  "codex_reasoning_effort": "medium",
  "claude_model": "claude-opus-4-8",
  "claude_effort": "medium",
  "agent_timeout_seconds": 7200,
  "projects": [
    {
      "name": "example",
      "enabled": true,
      "source_path": "/absolute/path/to/project",
      "repository": "owner/repository",
      "base_branch": "main",
      "checklist_file": "/absolute/path/to/private/example-organization.md",
      "validation_commands": [["pnpm", "run", "validate"]],
      "workspace": {
        "type": "linked-worktree",
        "setup_command": ["scripts/setup-worktree.sh", "--convex-mode", "local"],
        "cleanup_command": ["scripts/cleanup-worktree.sh"],
        "management_token_file": "/absolute/path/to/private/convex-management.token"
      }
    }
  ]
}
