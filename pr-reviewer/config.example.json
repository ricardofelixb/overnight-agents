{
  "version": 1,
  "skill_path": "./skills/autonomous-pr-review",
  "workspace_root": "./state/workspaces",
  "state_root": "./state",
  "docs_catalog": "./docs-catalog.json",
  "skills_lock": "./state/skills.lock.json",
  "telegram_env": "./.env",
  "defaults": {
    "mode": "observe",
    "model": "gpt-5.6-sol",
    "reasoning_effort": "high",
    "max_repair_iterations": 2,
    "command_timeout_seconds": 7200,
    "max_changed_files": 200,
    "max_diff_bytes": 1500000,
    "max_document_bytes": 5000000,
    "auto_fix_severities": ["P2", "P3"],
    "docs_max_age_hours": 24,
    "skill_max_age_days": 8,
    "check_timeout_seconds": 1800,
    "check_poll_seconds": 20,
    "require_required_checks": true,
    "approve_before_merge": false,
    "delete_branch": true,
    "telegram_notifications_enabled": true,
    "protected_policy_patterns": [
      "AGENTS.md",
      "**/AGENTS.md",
      "CLAUDE.md",
      "**/CLAUDE.md",
      ".agents/**",
      ".claude/**",
      ".codex/**",
      ".github/**",
      "package.json",
      "pnpm-lock.yaml",
      "package-lock.json",
      "yarn.lock",
      "bun.lock",
      "bun.lockb",
      "convex/_generated/ai/guidelines.md"
    ],
    "review_passes": [
      {
        "name": "behavior-contracts",
        "lens": "Behavioral equivalence, callers, contracts, deletions, error paths, and regression-sensitive tests"
      },
      {
        "name": "systems-boundaries",
        "lens": "Data integrity, concurrency, authentication, authorization, provider rules, security, performance, and operational safety"
      },
      {
        "name": "adversarial-security",
        "lens": "Threat-model the changed attack surface, tenant isolation, privilege boundaries, injection paths, secret exposure, unsafe deserialization, supply-chain behavior, and abuse cases"
      }
    ]
  },
  "projects": [
    {
      "name": "example",
      "enabled": false,
      "source_path": "/absolute/path/to/project",
      "repository": "owner/repository",
      "base_branch": "main",
      "allowed_head_patterns": ["code-simplify/*"],
      "allowed_authors": ["trusted-bot-or-user"],
      "allow_forks": false,
      "setup_commands": [["pnpm", "install", "--frozen-lockfile"]],
      "validation_commands": [["pnpm", "run", "validate"]],
      "validation_success_markers": [],
      "mode": "observe"
    }
  ]
}
