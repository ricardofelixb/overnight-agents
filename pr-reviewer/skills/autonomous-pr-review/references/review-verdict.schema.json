{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Autonomous PR review verdict",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "phase",
    "lens",
    "verdict",
    "reviewed_base_sha",
    "reviewed_head_sha",
    "risk",
    "summary",
    "behavioral_contracts",
    "findings",
    "coverage",
    "documentation",
    "blocking_reasons"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "phase": { "enum": ["analysis", "verification"] },
    "lens": { "type": "string", "minLength": 1, "maxLength": 120 },
    "verdict": { "enum": ["clean", "fixable", "blocked"] },
    "reviewed_base_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "reviewed_head_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "risk": { "enum": ["low", "medium", "high", "critical"] },
    "summary": { "type": "string", "minLength": 1, "maxLength": 2000 },
    "behavioral_contracts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["contract", "status", "evidence"],
        "properties": {
          "contract": { "type": "string", "minLength": 1 },
          "status": { "enum": ["preserved", "regressed", "uncertain"] },
          "evidence": { "type": "string", "minLength": 1 }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "severity",
          "confidence",
          "title",
          "file",
          "start_line",
          "end_line",
          "violated_invariant",
          "evidence",
          "regression_scenario",
          "impact",
          "recommended_fix",
          "required_validation",
          "auto_fix_safe"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,80}$" },
          "severity": { "enum": ["P0", "P1", "P2", "P3"] },
          "confidence": { "enum": ["high", "medium"] },
          "title": { "type": "string", "minLength": 1, "maxLength": 160 },
          "file": { "type": "string", "minLength": 1 },
          "start_line": { "type": "integer", "minimum": 1 },
          "end_line": { "type": "integer", "minimum": 1 },
          "violated_invariant": { "type": "string", "minLength": 1 },
          "evidence": { "type": "string", "minLength": 1 },
          "regression_scenario": { "type": "string", "minLength": 1 },
          "impact": { "type": "string", "minLength": 1 },
          "recommended_fix": { "type": "string", "minLength": 1 },
          "required_validation": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "auto_fix_safe": { "type": "boolean" }
        }
      }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "changed_files_reviewed",
        "changed_files_unreviewed",
        "callers_reviewed",
        "tests_reviewed",
        "domains"
      ],
      "properties": {
        "changed_files_reviewed": { "type": "array", "items": { "type": "string" } },
        "changed_files_unreviewed": { "type": "array", "items": { "type": "string" } },
        "callers_reviewed": { "type": "array", "items": { "type": "string" } },
        "tests_reviewed": { "type": "array", "items": { "type": "string" } },
        "domains": { "type": "array", "items": { "type": "string" } }
      }
    },
    "documentation": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["provider", "installed_version", "skill", "skill_revision", "url", "retrieved_at", "compatibility"],
        "properties": {
          "provider": { "type": "string", "minLength": 1 },
          "installed_version": { "type": ["string", "null"] },
          "skill": { "type": ["string", "null"] },
          "skill_revision": { "type": ["string", "null"] },
          "url": { "type": "string", "pattern": "^https://" },
          "retrieved_at": { "type": "string", "format": "date-time" },
          "compatibility": { "type": "string", "minLength": 1 }
        }
      }
    },
    "blocking_reasons": { "type": "array", "items": { "type": "string", "minLength": 1 } }
  }
}
