{
  "version": 1,
  "skill_path": "./skills/autonomous-pr-review",
  "simplifier_skill_path": "../pr-simplifier/skills/simplify-pr-implementation",
  "workspace_root": "./state/workspaces",
  "state_root": "./state",
  "docs_catalog": "./docs-catalog.json",
  "skills_lock": "./state/skills.lock.json",
  "telegram_env": "./.env",
  "webhook_env": "./.env",
  "defaults": {
    "mode": "repair",
    "model": "gpt-5.6-terra",
    "reasoning_effort": "high",
    "command_timeout_seconds": 7200,
    "max_changed_files": 200,
    "max_diff_bytes": 1500000,
    "max_review_context_bytes": 1000000,
    "max_ci_context_bytes": 1000000,
    "max_document_bytes": 5000000,
    "docs_max_age_hours": 24,
    "skill_max_age_days": 8,
    "ai_files_max_age_days": 8,
    "simplify_human_prs": true,
    "simplification_skip_head_patterns": ["code-simplify/*", "code-organize/*"],
    "telegram_notifications_enabled": true,
    "github_progress_enabled": true,
    "github_progress_heartbeat_seconds": 900,
    "review_comment_commands": ["/review"],
    "simplify_comment_commands": ["/simplify"],
    "review_comment_author_associations": ["OWNER", "MEMBER", "COLLABORATOR"],
    "validation_environment": {},
    "protected_policy_patterns": [
      "AGENTS.md",
      "**/AGENTS.md",
      "CLAUDE.md",
      "**/CLAUDE.md",
      ".agents/**",
      ".claude/**",
      ".codex/**",
      ".github/**",
      "convex/_generated/ai/guidelines.md"
    ],
    "protected_agent_edit_patterns": [
      "package.json",
      "pnpm-lock.yaml",
      "package-lock.json",
      "yarn.lock",
      "bun.lock",
      "bun.lockb"
    ]
  },
  "projects": [
    {
      "name": "example",
      "enabled": false,
      "source_path": "/absolute/path/to/project",
      "environment_file": "../code-simplifier/state/env/example.env.local",
      "repository": "owner/repository",
      "base_branch": "main",
      "allowed_head_patterns": ["*"],
      "excluded_authors": ["dependabot[bot]", "app/dependabot"],
      "allow_forks": false,
      "setup_commands": [["pnpm", "install", "--frozen-lockfile"]],
      "workspace_hooks": {
        "setup_command": ["scripts/setup-worktree.sh", "--convex-mode", "local"],
        "cleanup_command": ["scripts/cleanup-worktree.sh"]
      },
      "validation_commands": [["pnpm", "run", "validate"]],
      "mode": "repair"
    }
  ]
}
