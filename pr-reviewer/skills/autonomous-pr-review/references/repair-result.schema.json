{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Autonomous PR repair result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "phase",
    "status",
    "reviewed_head_sha",
    "accepted_findings",
    "rejected_findings",
    "changed_files",
    "tests_changed",
    "validation_commands",
    "blocking_reasons"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "phase": { "const": "repair" },
    "status": { "enum": ["repaired", "no_changes", "blocked"] },
    "reviewed_head_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "accepted_findings": { "type": "array", "items": { "type": "string" } },
    "rejected_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "reason"],
        "properties": {
          "id": { "type": "string" },
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    },
    "changed_files": { "type": "array", "items": { "type": "string" } },
    "tests_changed": { "type": "array", "items": { "type": "string" } },
    "validation_commands": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "blocking_reasons": { "type": "array", "items": { "type": "string", "minLength": 1 } }
  }
}
