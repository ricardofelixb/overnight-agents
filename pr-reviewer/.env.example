# Outbound-only Telegram notifications. No webhook or inbound listener is used.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Reserved for a possible future command bot; unused by the current notifier.
TELEGRAM_ALLOWED_USER_ID=

# Inbound GitHub webhook. Generate the live secret with configure_webhook.py.
GITHUB_WEBHOOK_SECRET=
GITHUB_WEBHOOK_HOST=127.0.0.1
GITHUB_WEBHOOK_PORT=8765
GITHUB_WEBHOOK_PATH=/github-webhook
GITHUB_WEBHOOK_PUBLIC_URL=https://your-host.example.ts.net:8443/github-webhook
