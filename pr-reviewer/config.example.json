{
  "version": 1,
  "skill_path": "./skills/autonomous-pr-review",
  "workspace_root": "./state/workspaces",
  "state_root": "./state",
  "docs_catalog": "./docs-catalog.json",
  "skills_lock": "./state/skills.lock.json",
  "telegram_env": "./.env",
  "defaults": {
    "mode": "repair",
    "model": "gpt-5.6-sol",
    "reasoning_effort": "high",
    "command_timeout_seconds": 7200,
    "max_changed_files": 200,
    "max_diff_bytes": 1500000,
    "max_review_context_bytes": 1000000,
    "max_document_bytes": 5000000,
    "docs_max_age_hours": 24,
    "skill_max_age_days": 8,
    "telegram_notifications_enabled": true,
    "validation_environment": {},
    "protected_policy_patterns": [
      "AGENTS.md",
      "**/AGENTS.md",
      "CLAUDE.md",
      "**/CLAUDE.md",
      ".agents/**",
      ".claude/**",
      ".codex/**",
      ".github/**",
      "package.json",
      "pnpm-lock.yaml",
      "package-lock.json",
      "yarn.lock",
      "bun.lock",
      "bun.lockb",
      "convex/_generated/ai/guidelines.md"
    ]
  },
  "projects": [
    {
      "name": "example",
      "enabled": false,
      "source_path": "/absolute/path/to/project",
      "repository": "owner/repository",
      "base_branch": "main",
      "allowed_head_patterns": ["code-simplify/*"],
      "allowed_authors": ["trusted-bot-or-user"],
      "allow_forks": false,
      "setup_commands": [["pnpm", "install", "--frozen-lockfile"]],
      "validation_commands": [["pnpm", "run", "validate"]],
      "validation_success_markers": [],
      "mode": "repair"
    }
  ]
}
